{
  "name": "beam",
  "version": "1.0.0",
  "description": "Beam — screen recorder and editor",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "electron-store": "8.2.0",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "vite": "^5.4.2"
  },
  "build": {
    "appId": "com.beamrecorder.app",
    "productName": "Beam",
    "mac": {
      "category": "public.app-category.video",
      "entitlements": "build/entitlements.mac.plist",
      "hardenedRuntime": true,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Beam needs microphone access to record audio with your screen capture.",
        "NSCameraUsageDescription": "Beam needs camera access to record webcam overlay.",
        "NSScreenCaptureUsageDescription": "Beam needs screen recording permission to capture your screen."
      }
    },
    "asarUnpack": [
      "node_modules/ffmpeg-static/**"
    ],
    "files": [
      "out/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
