{
  "name": "beam",
  "version": "1.0.0",
  "description": "Beam — screen recorder and editor",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder",
    "test": "npx playwright test",
    "test:screenshots": "npx playwright test screenshots.spec.js",
    "test:home": "npx playwright test home.spec.js",
    "test:editor": "npx playwright test editor.spec.js",
    "test:ipc": "npx playwright test ipc.spec.js"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "electron-store": "8.2.0",
    "electron-updater": "^6.3.9",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^4.3.1",
    "dotenv": "^17.4.2",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "vite": "^5.4.2"
  },
  "build": {
    "appId": "com.beamrecorder.app",
    "productName": "Beam",
    "icon": "resources/icon.png",
    "afterSign": "build/notarize.js",
    "mac": {
      "icon": "resources/icon.icns",
      "category": "public.app-category.video",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": false,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Beam needs microphone access to record audio with your screen capture.",
        "NSCameraUsageDescription": "Beam needs camera access to record webcam overlay.",
        "NSScreenCaptureUsageDescription": "Beam needs screen recording permission to capture your screen."
      }
    },
    "win": {
      "icon": "resources/icon.ico"
    },
    "linux": {
      "icon": "resources/icon.png"
    },
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/ffprobe-static/**"
    ],
    "files": [
      "out/**/*",
      "resources/**"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
